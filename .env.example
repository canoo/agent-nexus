# NEXUS Environment Configuration
# Copy this file to .env to override defaults

# URL of your local or network LLM node (Defaults to localhost if unset)
# OLLAMA_HOST_URL="http://localhost:11434"

# ── Model Overrides ──────────────────────────────────────────────────────────
# Override the default models used by the MCP server.
# See docs/model-configuration.md for hardware-specific presets.
#
# Band-level overrides (replaces all tasks in that band):
# NEXUS_SUPERVISOR_MODEL="qwen2.5-coder:1.5b"
# NEXUS_LOGIC_MODEL="llama3.2:3b"
#
# Per-task overrides (takes priority over band-level):
# NEXUS_MODEL_COMMIT_MSG="qwen2.5-coder:1.5b"
# NEXUS_MODEL_BOILERPLATE="qwen2.5-coder:1.5b"
# NEXUS_MODEL_TEST_SCAFFOLD="qwen2.5-coder:1.5b"
# NEXUS_MODEL_LINT_FIX="llama3.2:3b"
# NEXUS_MODEL_LOGIC_REFACTOR="llama3.2:3b"
